                                 (tunsigned 65535)
                                 (tunsigned 65535))])
             (ttuple (tunsigned 65535) (tunsigned 65535))
          %x.2)
        (circuit %bar.3 ([%y.4 (ttuple
                                 (tunsigned 255)
                                 (tunsigned 255))])
             (tunsigned 4294967295)

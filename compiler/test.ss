      "export circuit member(key: Uint<64>): Boolean {"
      "  return fld.member(disclose(key));"
      "}"
      ""
      "export circuit lookup(key: Uint<64>): Boolean {"
      "  return fld.lookup(disclose(key));"
      "}"
      ""
      "export circuit isEmpty(): Boolean {"

                  (foo #f ((tunsigned 255)) (tfield))
                  (bar #t () (tfield))))))
           (constructor ([%c.2 (tcontract C
                                 (foo #f ((tunsigned 255)) (tfield))
                                 (bar #t () (tfield)))])
             (seq (public-ledger %contract_c.1 (0) write %c.2) (tuple))))
         (circuit %docall.3 ([%c.4 (tcontract C
                                     (foo #f ((tunsigned 255)) (tfield))
                                     (bar #t () (tfield)))])
              (tfield)

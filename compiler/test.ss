        ,(format "  await expect(C.circuits.foo(context, ~dn, ~:*~dn-1n)).rejects.toThrow('type error: foo argument 1 at testfile.compact line 1 char 1; expected value of type Field but received ~:*~dn');" (+ (max-field) 1))

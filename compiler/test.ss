             (tboolean)
          (call %foo.2
            (enum-ref (tenum Names bill sally fred george) bill)))
        (circuit %mice.5 ()
             (tboolean)
          (call %foo.2
            (call %enumid.0
              (enum-ref (tenum Names bill sally fred george) george))))))

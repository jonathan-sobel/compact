  (test
    '(
      "import CompactStandardLibrary;"
      "witness bar(x: Field): Uint<0..36>;"
      "export circuit foo(x: Uint<0..36>): Uint<0..36> {"
      "  return x - x as Uint<0..36>;"
      "}"

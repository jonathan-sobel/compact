  (test
    '(
      "export circuit foo(n: Uint<3>, v1: Vector<4, Field>, v2: Vector<4, Uint<8>>): Vector<4, Field> {"
      "  return map("
      "    (x, y, z) => {"
      "      return x + y + z;"
      "    },"

      "circuit foo(x : Field) : Boolean { return (A{a: x, b: 7}).b; }"
      )
    (returns
      (program
        (circuit #f #f foo () ([x (tfield)])
             (tboolean)
          (block (return (elt-ref (new (type-ref A) (a x) (b 7)) b)))))))

  (test
    '(
      "circuit foo(x : Field) : Boolean { return x + x * 3 - 4 == 17 || x == 5 && !(x * 3 + x == 8); }"
      )
    (returns
      (program
        (circuit #f #f foo () ([x (tfield)])
             (tboolean)
          (block
            (return
              (or (== (- (+ x (* x 3)) 4) 17)
                  (and (== x 5) (not (== (+ (* x 3) x) 8))))))))))

  (test
   '(

      "}"
      )
    (returns
      (program
        (circuit #t #f foo () ([x (tboolean)] [y (tboolean)])
             (tfield)
          (block (return (if x (+ 3 4) (if y (+ 5 6) 7)))))))
    )

  (test
    '(
      "export circuit foo(): Bytes<10> {"
      "  return pad(10, 'abcdefghij');"
      "}"
      )
    (returns
      (program
        (circuit #t #f foo () ()
             (tbytes 10)
          (block
            (return #vu8(97 98 99 100 101 102 103 104 105 106))))))
    )

  (test
    '(

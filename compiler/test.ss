        (constructor ([%c.1 (tcontract C
                              (foo #f ((tbytes 32)) (ttuple))
                              (bar #t () (tbytes 32))
                              (blah #f ((tfield) (tboolean)) (tboolean)))])
          (seq (= %contract_c.0 (disclose %c.1)) (tuple)))
        (circuit %hello.2 ([%x.3 (tfield)] [%y.4 (tboolean)])

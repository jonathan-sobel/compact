                              (tuple-ref %v.3 0)
                              (tuple-ref %v.3 1)
                              (tuple-ref %v.3 2))])
                      (tuple
                        (let* ([[%x.7 (tfield)] (tuple-ref %t.5 0)]
                               [[%y.8 (tfield)] (tuple-ref %t.6 0)])
                          (+ #f %x.7 %y.8))
                        (let* ([[%x.9 (tfield)] (tuple-ref %t.5 1)]
                               [[%y.10 (tfield)] (tuple-ref %t.6 1)])

  ; issue 226
  (let* ([len (+ (* (field-bytes) 3) 1)]
         [yes (- (expt 256 len) 1)]
         [yes* (let f ([yes yes] [len len]) (if (fx= len 0) '() (cons (modulo yes 256) (f (quotient yes 256) (fx- len 1)))))])
  (test

        "test('check 2a', async () => {"
        "  const [C, Ctxt] = await startContract(contractCode, witnesses, 0);"
        "  await expect(C.circuits.foo(Ctxt, 37n)).rejects.toThrow(runtime.CompactError);"
        "});"
        "test('check 2b', async () => {"

        "  expect((await C.circuits.vector16$foo(Ctxt, [17n, 23n, 29n, 31n, 37n])).result).toEqual([17n, 23n, 29n, 31n, 37n]);"
        "  expect((await C.circuits.tuple16$foo(Ctxt, [true, 101n])).result).toEqual([true, 101n]);"

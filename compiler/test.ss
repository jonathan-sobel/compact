      "circuit A<#t>(x: Uint<t..37>): Field {"
      "  return x;"
      "}"
      "circuit A<t>(x: t): Field {"
      "  return x ? 1 : 0;"
      "}"
      "circuit A<t>(x: Uint<16>): Field {"
      "  return x;"
      "}"
      "export circuit B(x: Uint<0..8>): Field {"

  (test
    '(
      "ledger fld: Vector<1, Field>;"
      "export circuit foo(v: Vector<1, Field>): [] {"
      "  fld = disclose(v);"
      "}"
      "export circuit Foo(x: Field): [] {"
      "  fld = [disclose(x)];"
      "}"
      )
    (oops
      message: "~a:\n  ~?"
      irritants: '("testfile.compact line 2 char 1" "the exported impure circuit name ~a is identical to the exported circuit name ~s at ~a modulo case; please rename to avoid zkir and prover-key filename clashes on case-insensitive filesystems" ("foo" "Foo" "line 5 char 1")))
    )

  (test
    '(
      "ledger fld: Vector<1, Field>;"
      "circuit Mfoo(v: Vector<1, Field>): [] {"
      "  fld = disclose(v);"
      "}"
      "module M {"
      "  export circuit Foo(x: Field): [] {"
      "    fld = [disclose(x)];"
      "  }"
      "}"
      "import M prefix M;"
      "export { Mfoo, MFoo }"
      )
    (oops
      message: "~a:\n  ~?"
      irritants: '("testfile.compact line 2 char 1" "the exported impure circuit name ~a is identical to the exported circuit name ~s at ~a modulo case; please rename to avoid zkir and prover-key filename clashes on case-insensitive filesystems" ("Mfoo" "MFoo for Foo" "line 6 char 3")))
    )

  (test
    '(
      "circuit bar(v: Vector<5, Field>, i: Uint<0..4>): Field {"
      "  return v[i];"
      "}"
      "export circuit foo(v: Vector<5, Field>): Field {"
      "  return bar(v, 3);"
      "}"
      )
    (returns (program))
    )

  (test
    '(
      "ledger F: Field;"
      "circuit bar(v: Vector<5, Field>, i: Uint<0..5>): Field {"
      "  F = disclose(v[i]);"
      "  return F;"
      "}"
      "export circuit foo(v: Vector<5, Field>): Field {"
      "  return bar(v, 3);"
      "}"
      )
    (returns
      (program
        (circuit (foo) ((%v.0 "Scalar<BLS12-381>")
                        (%v.1 "Scalar<BLS12-381>")
                        (%v.2 "Scalar<BLS12-381>")
                        (%v.3 "Scalar<BLS12-381>")
                        (%v.4 "Scalar<BLS12-381>"))
          ("Scalar<BLS12-381>")
          (impact 1 16 1 1 1 0 17 1 1 -2 %v.3 145)
          (public_input "Scalar<BLS12-381>" %t.5)
          (impact 1 48 80 1 1 0 12 1 -2 %t.5)
          (output %t.5))))
    )

  (test
    '(
      "import CompactStandardLibrary;"
      "export ledger x: Counter;"
      "export circuit foo(v: Vector<5, Uint<16>>): [] {"
      "  for (const i of 2..5) x += disclose(v[i] - v[i-1]);"
      "}"
      )
    (returns
      (program
        (circuit (foo) ((%v.10 "Scalar<BLS12-381>")
                        (%v.0 "Scalar<BLS12-381>")
                        (%v.1 "Scalar<BLS12-381>")
                        (%v.4 "Scalar<BLS12-381>")
                        (%v.7 "Scalar<BLS12-381>"))
          ()
          (constrain_bits %v.10 16)
          (constrain_bits %v.0 16)
          (constrain_bits %v.1 16)
          (constrain_bits %v.4 16)
          (constrain_bits %v.7 16)
          (less_than %t.2 %v.1 %v.0 16)
          (cond_select %t.3 %t.2 0 1)
          (assert %t.3)
          (neg %neg.11 %v.0)
          (add %tmp.12 %v.1 %neg.11)
          (impact 1 112 1 1 0 14 %tmp.12 161)
          (less_than %t.5 %v.4 %v.1 16)
          (cond_select %t.6 %t.5 0 1)
          (assert %t.6)
          (neg %neg.13 %v.1)
          (add %tmp.14 %v.4 %neg.13)
          (impact 1 112 1 1 0 14 %tmp.14 161)
          (less_than %t.8 %v.7 %v.4 16)
          (cond_select %t.9 %t.8 0 1)
          (assert %t.9)
          (neg %neg.15 %v.4)
          (add %tmp.16 %v.7 %neg.15)
          (impact 1 112 1 1 0 14 %tmp.16 161))))
    )


     "  const x : Field = 10, y : Field = 20, z = 30;"
     "  return y;"
     "}"
     )
   (returns
      (program
        (circuit #f #f foo () ()
             (tfield)
          (block
            (const ([x (tfield) 10] [y (tfield) 20]
                    [z (tundeclared) 30]))
            (return y)))))
   )


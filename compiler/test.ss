                                 %y.4))
                             0))
                         (safe-cast (tunsigned 131070)
                                    (tunsigned 65535)
                           (tuple-ref
                             (call %foo.1
                               (safe-cast (ttuple
                                            (tunsigned 65535)
                                            (tunsigned 65535))
                                          (ttuple (tunsigned 255) (tunsigned 255))
                                 %y.4))
                             1))))
                    (safe-cast (tunsigned 196605)
                               (tunsigned 65535)
                      (tuple-ref
                        (call %foo.1
                          (safe-cast (ttuple (tunsigned 65535) (tunsigned 65535))
                                     (ttuple (tunsigned 255) (tunsigned 255))
                            %y.4))
                        0))))
               (safe-cast (tunsigned 262140)
                          (tunsigned 65535)
                 (tuple-ref

             (tfield)
          (= #t %t.4 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.5 (bytes->field 20 %arg.3))
          %t.5))))

  (test
    '(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo(arg: Field) : Bytes<20> { forceProof(); return arg as Bytes<20>; }"
     )
    (returns

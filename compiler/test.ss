(run-tests combine-ledger-declarations
  (test
    '(
      "import CompactStandardLibrary;"
      "ledger field1: Counter;"
      "export ledger field2: Counter;"
      "constructor() {}"
      "ledger field3: Counter;"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 (Kernel)))
        (public-ledger-declaration
          (%field1.1 (Counter))
          (%field2.2 (Counter))
          (%field3.3 (Counter))
          (constructor () (tuple)))))
    )


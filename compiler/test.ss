             (tbytes 20)
          (= #t %t.4 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.5 (field->bytes 20 %arg.3))
          %t.5))))

  (test
    '(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "module A<#n, t> {"
      "  export circuit foo(v : Vector<n, t>, b : Bytes<n>): Field {"
      "    forceProof();"
      "    return 17;"
      "  }"
      "}"
      "module B {"
      "  circuit foo(x : Field): Field { forceProof(); return x + 1; }"
      "  circuit bar(x : Field): Field { forceProof(); return x - 1; }"
      "  import A<7, Field> prefix AA;"
      "  import A<30, Boolean> prefix AAA;"
      "  export {foo, AAfoo, AAAfoo, bar}"
      "}"
      "import B;"
      "import B prefix BB;"
      "import B<> prefix BBB;"
      "export {foo, AAfoo, BBfoo, BBAAfoo, BBBfoo, BBBAAAfoo, bar, BBbar, BBBbar}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ([%v.3 (tvector 7 (tfield))]
                         [%b.4 (tbytes 7)])
             (tfield)
          (= #t %t.5 (public-ledger %forceField.1 (0) write 7))
          17)
        (circuit %foo.6 ([%v.7 (tvector 30 (tboolean))]
                         [%b.8 (tbytes 30)])
             (tfield)
          (= #t %t.9 (public-ledger %forceField.1 (0) write 7))
          17)
        (circuit %foo.10 ([%x.11 (tfield)])
             (tfield)
          (= #t %t.12 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.13 (+ #f %x.11 1))
          %t.13)
        (circuit %bar.14 ([%x.15 (tfield)])
             (tfield)
          (= #t %t.16 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.17 (- #f %x.15 1))
          %t.17)))
    )

  (test
    '(
      "import CompactStandardLibrary;"
      "ledger field1: Counter;"
      ""
      "export circuit foo(): Field {"
      "  return field1.read();"
      "}"
      )
    (returns

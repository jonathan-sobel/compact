      "export circuit bar2(x: Opaque<'frob'>): S<Opaque<'frob'>> { return S<Opaque<'frob'>>{ p: foo<Opaque<'frob'>>(x), q: 2 }; }"
      "export circuit bar3(x: Opaque<'string'>): S<Opaque<'string'>> { return S<Opaque<'string'>>{ p: foo<Opaque<'string'>>(x), q: 3 }; }"

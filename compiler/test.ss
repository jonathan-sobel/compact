        (circuit %A.2 ([%x.3 (tunsigned 65535)])
             (tfield)
          (safe-cast (tfield) (tunsigned 65535) %x.3))
        (circuit %B.4 ([%x.5 (tunsigned 7)])
             (tfield)
          (call %A.2 (safe-cast (tunsigned 65535) (tunsigned 7) %x.5)))))
    )


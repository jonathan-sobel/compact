  (test
    '(
      "circuit foo(v: Vector<10, Field>): Boolean {"
      "  return fold("
      "          (b: Boolean, x: Field): Boolean => {"
      "            const y = x;"
      "            {"
      "              const k = 0;"
      "              return b && x == k;"
      "            }"
      "          },"
      "          true,"
      "          v);"
      "}"
      )
    (returns
      (program
        (circuit #f #f foo () ([v (tvector 10 (tfield))])
             (tboolean)
          (fold (circuit ([b (tboolean)] [x (tfield)])
                     (tboolean)
                  (block (y)
                    (let* ([[y (tundeclared)] x])
                      (block (k)
                        (let* ([[k (tundeclared)] 0]) (and b (== x k)))))))
            #t
            v))))

        ,(format "  expect((await C.circuits.foo(Ctxt, false, new Uint8Array([~{0x~x~^, ~}]))).result).toEqual(0x~xn);" yes* 0)
        ,(format "  expect((await C.circuits.foo(Ctxt, true, new Uint8Array([~{0x~x~^, ~}]))).result).toEqual(0x~xn);" yes* yes)
        "  });"
        ))
    )
  )


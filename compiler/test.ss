      "  export circuit bar2(x: Bytes<10>): S<Bytes<10>> { return S<Bytes<10>>{p: foo<Bytes<10>, Vector<n, b>>(x, [1, 2, 3]), q: 2}; }"
      "  export circuit bar3(x: Bytes<11>): S<Bytes<11>> { return S<Bytes<11>>{p: foo<Bytes<11>, Vector<n, b>>(x, [1, 2, 3]), q: 3}; }"

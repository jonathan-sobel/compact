        "    { \"op\": \"impact\", \"guard\": \"0x01\", \"inputs\": [\"0x70\", \"0x01\", \"0x01\", \"0x00\", \"0x0e\", \"%t.20\", \"0xa1\"] }"
        "  ]"
        "}"))
    )


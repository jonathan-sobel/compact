             (ty ((afield)) ((tfield)))
          (= 1 () (public-ledger %forceField.6 (0) write 7))
          (= 1 %t.1 (== %arg.0 0))
          (assert %t.1 "bytes value is too big to fit in a field")
          (= 1 %t.4 (bytes->field 80 %arg.3 %arg.2))
          (= 1 %t.8 (+ #f %t.4 %t.4))
          (%t.8))))
    )


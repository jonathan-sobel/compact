                (%c.4
                 (tcontract C
                   (foo #f ((tunsigned 255)) (tfield))
                   (bar #t () (tfield))))))
         (circuit %hello.5 ()
              (tfield)
           (call %docall.3 (public-ledger %contract_c.1 (0) read)))))

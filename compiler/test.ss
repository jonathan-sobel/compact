      "  const s2 = S { ...s1, b: true };"
      "  const s3 = S { ...s2, c: 'abcdefgh' };"
      "  return s3;"
      "}"
      )
    (returns
      (program
        (circuit %F.0 ([%a.1 (tunsigned 4294967295)]
                       [%b.2 (tboolean)]
                       [%c.3 (tbytes 8)])
             (tstruct S
               (a (tunsigned 4294967295))
               (b (tboolean))
               (c (tbytes 8)))
          (let* ([[%s1.4 (tstruct S
                           (a (tunsigned 4294967295))
                           (b (tboolean))
                           (c (tbytes 8)))]
                  (new (tstruct S
                         (a (tunsigned 4294967295))
                         (b (tboolean))
                         (c (tbytes 8)))
                    %a.1
                    %b.2
                    %c.3)])
            (let* ([[%s2.5 (tstruct S
                             (a (tunsigned 4294967295))
                             (b (tboolean))
                             (c (tbytes 8)))]
                    (new (tstruct S
                           (a (tunsigned 4294967295))
                           (b (tboolean))
                           (c (tbytes 8)))
                      (elt-ref %s1.4 a 0)
                      #t
                      (elt-ref %s1.4 c 2))])
              (let* ([[%s3.6 (tstruct S
                               (a (tunsigned 4294967295))
                               (b (tboolean))
                               (c (tbytes 8)))]
                      (new (tstruct S
                             (a (tunsigned 4294967295))
                             (b (tboolean))
                             (c (tbytes 8)))
                        (elt-ref %s2.5 a 0)
                        (elt-ref %s2.5 b 1)
                        #vu8(97 98 99 100 101 102 103 104))])
                %s3.6))))))

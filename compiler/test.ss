  (test
    '(
      "// Hi!"
      "/* what's up? */"
      ""
      "/*0*/ module /*1*/ M /*3*/ { /*4*/"
      "  /*5*/"
      "  export module N<#N, T> {"
      "  }"
      ""
      "  export struct S { x: Uint<16>, y: Uint<0..78> }"

              (and %x.13 (== %n.11 (safe-cast (tfield) (tunsigned 0) 0))))))
        (circuit %bar.14 ([%n.15 (tfield)])
             (tfield)
          (if (call %foo.10 (+ #f %n.15 (safe-cast (tfield) (tunsigned 1) 1)))

            (circuit ([%b.2 (tboolean)] [%x.3 (tfield)])
                 (tboolean)
              (let* ([[%y.4 (tfield)] %x.3])
                (let* ([[%x.5 (tfield)] (* #f
                                           %y.4
                                           (safe-cast (tfield) (tunsigned 1)
                                             1))])
                  (if %b.2
                      (== %x.5 (safe-cast (tfield) (tunsigned 0) 0))
                      #f))))

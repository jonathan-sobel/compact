                 [[%t.14 (tvector 1 (tfield))] %v.11]
                 [[%t.15 (tvector 1 (tbytes 20))] %w.12])
            (let* ([[%b.16 (tboolean)] %t.13]
                   [[%n.17 (tfield)] (tuple-ref %t.14 0)]

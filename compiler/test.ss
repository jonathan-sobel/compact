      )
    (returns
      (program
        (public-ledger-declaration #t #f field1 (type-ref Counter))
        (circuit #f #f foo () ([state (tunsigned 16)])
             (tunsigned 16)
          (block
            (+= field1 state)
            (-= field1 state)
            (return 0)))))
    )


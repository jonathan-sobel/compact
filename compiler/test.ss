  (test
    '(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "witness spam(): Bytes<32>;"
      "export circuit foo(): Field {"
      "  forceProof();"
      "  return disclose(spam()) as Field;"
      "}"
     )
      (output-file "compiler/testdir/zkir/foo.zkir"
      '(
        "{"

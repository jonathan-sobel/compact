             (ty ((abytes 1)) ((tfield 255)))
          (= 1 () (public-ledger %forceField.4 (0) write 7))
          (= 1 %t.1 (< 32 %x.0 256))
          (= 1 %t.2 (downcast-unsigned #t 4294967295 255 %x.0))
          (= 1 %t.6 (select %t.1 %t.2 0))

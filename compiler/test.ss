        "    { \"op\": \"assert\", \"cond\": \"%t.8\" },"
        "    { \"op\": \"neg\", \"output\": \"%neg.9\", \"a\": \"%z.3\" },"
        "    { \"op\": \"add\", \"output\": \"%t.10\", \"a\": \"%y.2\", \"b\": \"%neg.9\" },"
        "    { \"op\": \"mul\", \"output\": \"%t.11\", \"a\": \"%q.4\", \"b\": \"%t.10\" },"

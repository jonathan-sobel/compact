        ,(format "  expect((await C.circuits.foo(Ctxt, false, new Uint8Array([~{0x~x~^, ~}]))).result).toEqual(0x~xn);" yes* 0)
        ,(format "  await expect(C.circuits.foo(Ctxt, true, new Uint8Array([~{0x~x~^, ~}]))).rejects.toThrow(runtime.CompactError);" yes*)
        "  });"

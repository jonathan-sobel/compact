      "  return pad(10, 'abcdefghijkl');"
      "}"
      )
    (oops
      message: "~a:\n  ~?"
      irritants: '("testfile.compact line 2 char 10" "cannot pad ~s to length ~s since its utf8-equivalent already exceeds that length" ("abcdefghijkl" 10)))
    )


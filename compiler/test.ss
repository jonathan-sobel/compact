  (test
    '(
      "ledger impure: Boolean;"
      "circuit foo(a: Field, n: Field, b: Boolean): Field {"
      "  impure = true;"
      "  return a + (b ? n + 1 : n - 1);"
      "}"
      "export circuit bar(nv: Vector<7, Field>, bv: Vector<7, Boolean>): Field {"
      "  impure = true;"
      "  return fold(foo, 17, nv, bv);"

(run-tests reduce-to-circuit
  (test
    `(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo(b: Boolean, x: Field): Boolean {"
      "  forceProof();"
      "  return true;"
      "}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ([%b.3 (tboolean)] [%x.4 (tfield)])
             (tboolean)
          (= #t %t.5 (public-ledger %forceField.1 (0) write 7))
          #t)))
    )

  (test
    `(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo(b: Boolean, x: Field): Boolean {"
      "  forceProof();"
      "  assert(x == 3, 'oops 1');"
      "  return b;"
      "}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ([%b.3 (tboolean)] [%x.4 (tfield)])
             (tboolean)
          (= #t %t.5 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.6 (== %x.4 3))
          (= #t %t.7 (select #t %t.6 #t))
          (assert %t.7 "oops 1")
          (= #t %t.8 (tuple))
          %b.3)))
    )

  (test
    `(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo(b: Boolean, x: Uint<16>): Boolean {"
      "  forceProof();"
      "  assert(x < 3, 'oops 1');"
      "  return b;"
      "}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ([%b.3 (tboolean)] [%x.4 (tunsigned 65535)])
             (tboolean)
          (= #t %t.5 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.6 (< 16 %x.4 3))
          (= #t %t.7 (select #t %t.6 #t))
          (assert %t.7 "oops 1")
          (= #t %t.8 (tuple))
          %b.3)))
    )

  (test
    `(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo(b: Boolean, x: Field): Boolean {"
      "  forceProof();"
      "  if (b)"
      "     assert(b, 'oops 1');"
      "  else"
      "     assert(x == 3, 'oops 2');"
      "  return b && x == 3;"
      "}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ([%b.3 (tboolean)] [%x.4 (tfield)])
             (tboolean)
          (= #t %t.5 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.6 (select %b.3 #t #f))
          (= #t %t.7 (select %b.3 #f #t))
          (= %t.6 %t.8 (tuple))
          (= %t.7 %t.9 (== %x.4 3))
          (= #t %t.10 (select %t.7 %t.9 #t))
          (assert %t.10 "oops 2")
          (= %t.7 %t.11 (tuple))
          (= #t %t.12 (select %b.3 #t #f))
          (= #t %t.13 (select %b.3 #f #t))
          (= %t.12 %t.14 (== %x.4 3))
          (= #t %t.15 (select %b.3 %t.14 #f))
          %t.15)))
    )

  (test
    `(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit foo() : Vector<3, Vector<2, Field>> {"
      "  forceProof();"
      "  return [[1, 2], [3, 4], [5, 6]];"
      "}"
      )
    (returns
      (program
        (kernel-declaration (%kernel.0 () (Kernel)))
        (public-ledger-declaration
          ((%forceField.1 (0) (__compact_Cell (tfield)))))
        (circuit %foo.2 ()
             (tvector 3 (tvector 2 (tfield)))
          (= #t %t.3 (public-ledger %forceField.1 (0) write 7))
          (= #t %t.4 (tuple 1 2))
          (= #t %t.5 (tuple 3 4))
          (= #t %t.6 (tuple 5 6))
          (= #t %t.7 (tuple %t.4 %t.5 %t.6))
          %t.7)))
    )

  (test
    '(
      "ledger forceField: Field; circuit forceProof(): [] { forceField = 7; }"
      "export circuit baz(arg: Bytes<20>) : Field { forceProof(); return arg as Field; }"
     )
    (returns

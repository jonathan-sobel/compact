             (talias #f U33 (tunsigned 8589934591))
          (safe-cast (talias #f U33 (tunsigned 8589934591))
                     (tunsigned 8589934590)
            (let* ([[%x.3 (tunsigned 4294967295)] (call %bar.1)])
              (+ 33
                 (safe-cast (tunsigned 8589934590)
                            (tunsigned 4294967295)

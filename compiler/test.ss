  (test
    `(
      "import CompactStandardLibrary;"
      "export circuit foo(f: Field): [] {"
      ,(format "  const x = transientHash<~a>(f);"
               ((lambda (n)
                    (let loop ([i 0] [result '()])
                      (if (= i n)
                          (format #f "[~{~a~^, ~}]" (reverse result))
                          (loop (+ i 1) (cons "Field" result))))) (+ (max-bytes/vector-length) 1)))

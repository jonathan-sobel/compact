      "ledger f17: Field;"
      "ledger f18: Field;"
      "ledger f19: Field;"
      "ledger f20: Field;"
      "ledger f21: Field;"
      "ledger f22: Field;"
      "ledger f23: Field;"
      "ledger f24: Field;"

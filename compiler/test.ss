  (test ;; spread must come before all elements.
    '(
      "struct S { a: Uint<32>, b: Boolean, c: Bytes<8> }"
      "export circuit F(a: Uint<32>, b: Boolean, c: Bytes<8>): S {"
      "  const s1 = S { c: c, a: a, b: b };"
      "  const s2 = S { b: true, ...s1};"
      "  const s3 = S { ...s2, c: 'abcdefgh' };"
      "  return s3;"
      "}"

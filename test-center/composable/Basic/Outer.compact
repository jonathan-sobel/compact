contract Inner {
  circuit add(value: Field): Field;
}

export ledger inner: Inner;

constructor(i: Inner) {
  inner = disclose(i);
}

export circuit add(value: Field): Field {
  return inner.add(disclose(value));
}

export circuit setInner(i: Inner): Inner {
  const lastInner = inner;
  inner = disclose(i);
  return lastInner;
}

export circuit echoStored(): Inner {
  const a = inner;
  const b = a;
  return b;
}

export circuit echoInner(i: Inner): Inner {
  const a = i;
  const b = a;
  return disclose(b);
}

export circuit addViaConst(value: Field): Field {
  const target = inner;
  return target.add(disclose(value));
}

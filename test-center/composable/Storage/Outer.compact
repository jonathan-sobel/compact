// Exercises contract values stored inside complex ledger ADTs. Because a
// contract value flattens to a contract address (Bytes<32>) it should be
// storable anywhere an ordinary value is: as a Map value, a List element,
// and a MerkleTree leaf.

import CompactStandardLibrary;

contract Inner {
  circuit add(value: Field): Field;
}

export ledger registry: Map<Field, Inner>;
export ledger queue: List<Inner>;
export ledger tree: MerkleTree<2, Inner>;

// --- Map<Field, Inner> -------------------------------------------------------

export circuit register(key: Field, i: Inner): [] {
  registry.insert(disclose(key), disclose(i));
}

export circuit getRegistered(key: Field): Inner {
  return registry.lookup(disclose(key));
}

export circuit isRegistered(key: Field): Boolean {
  return registry.member(disclose(key));
}

// --- List<Inner> -------------------------------------------------------------

export circuit enqueue(i: Inner): [] {
  queue.pushFront(disclose(i));
}

export circuit peek(): Inner {
  return queue.head().value;
}

// --- MerkleTree<2, Inner> ----------------------------------------------------

export circuit store(i: Inner): [] {
  tree.insert(disclose(i));
}

export circuit treeFull(): Boolean {
  return tree.isFull();
}
